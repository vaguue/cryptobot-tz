NODE_ENV=development
HTTP_PORT=3000

# Mongo — same as repo root `.env` (MONGO_INITDB_ROOT_*) / `docker compose up mongo`
MONGO_URI=mongodb://seva:ms6CvqeG6rKykZm@127.0.0.1:27017/?authSource=admin
MONGO_DB_NAME=clicker

ALLOWED_ORIGINS=http://localhost:5173

# JWT for POST /api/auth/telegram (required always; use a long random string)
JWT_SECRET=change_me_to_a_long_random_secret_at_least_8_chars

# Dev: use X-User-Id header only (see frontend VITE_SKIP_AUTH). Production: JWT cookie + Telegram
SKIP_AUTH=true

# Skip validating initData (dev only); uses DEV_TELEGRAM_USER_ID for POST /api/auth
SKIP_INIT_DATA=false
DEV_TELEGRAM_USER_ID=12345

# Required when SKIP_AUTH=false and SKIP_INIT_DATA=false
TELEGRAM_BOT_TOKEN=

# Optional reCAPTCHA v3 (header recaptcha-token on requests)
RECAPTCHA_SECRET_KEY=

MAX_CLICKS_PER_WINDOW=120
CLICK_RATE_WINDOW_MS=10000
