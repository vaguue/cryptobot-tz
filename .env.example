# Copy to `.env` and adjust. Used by docker compose and (optionally) backend connection string.

# MongoDB (Docker `mongo` service — root user in `admin` DB)
MONGO_INITDB_ROOT_USERNAME=seva
MONGO_INITDB_ROOT_PASSWORD=ms6CvqeG6rKykZm
MONGO_PORT=27017

# App database name (not the auth DB)
MONGO_DB_NAME=clicker

# Backend HTTP (docker-compose `backend` service and local dev)
# HTTP_PORT=3000

# Frontend: optional absolute API base for production builds (e.g. https://api.example.com/api).
# Dev uses Vite proxy to localhost:3000; leave unset for relative /api.
# VITE_API_URL=
